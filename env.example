# Copy this to Railway's environment variables panel.
# Railway sets DATABASE_URL automatically when you add a PostgreSQL plugin.

# Required
SECRET_KEY=generate-a-long-random-string-here
DEBUG=False
ALLOWED_HOSTS=your-app-name.up.railway.app,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://your-app-name.up.railway.app,https://yourdomain.com
DJANGO_SETTINGS_MODULE=management_system.settings
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Set automatically by Railway (do not change)
# DATABASE_URL=postgresql://...

# Optional email settings (use real SMTP credentials in production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your@gmail.com

# Copy this to Railway's environment variables panel.
# Railway sets DATABASE_URL automatically when you add a PostgreSQL plugin.

# Required
SECRET_KEY=your-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
DJANGO_SETTINGS_MODULE=management_system.settings
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Set automatically by Railway (do not change)
# DATABASE_URL=postgresql://...

# Email (required for password reset and notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Copy these to your Render service's environment variables.
# Render sets DATABASE_URL automatically when you attach a PostgreSQL database.

# Required — set manually in Render dashboard
SECRET_KEY=your-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=erp-pc57.onrender.com
CSRF_TRUSTED_ORIGINS=https://erp-pc57.onrender.com
DJANGO_SETTINGS_MODULE=management_system.settings
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Set automatically by Render when database is attached (do not change)
# DATABASE_URL=postgresql://...

# Email (required for password reset and notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
